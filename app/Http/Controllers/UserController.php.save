<?php

namespace App\Http\Controllers;

use App\Models\User;
use App\Models\LostItem;
use App\Models\FoundItem;
use App\Models\ItemMatch;
use Illuminate\Http\Request;
use Illuminate\Support\Facades\Auth;
use Illuminate\Support\Facades\Hash;
use Illuminate\Support\Facades\Storage;
use Illuminate\Validation\Rule;
use Illuminate\Validation\Rules\Password;

class UserController extends Controller
{
    /**
     * Display a listing of users (Admin only)
     */
    public function index(Request $request)
    {
        $this->authorize('viewAny', User::class);
        
        $query = User::query();
        
        // Search functionality
        if ($request->filled('search')) {
            $search = $request->get('search');
            $query->where(function ($q) use ($search) {
                $q->where('name', 'like', "%{$search}%")
                  ->orWhere('email', 'like', "%{$search}%");
            });
        }
        
        // Filter by role
        if ($request->filled('role') && in_array($request->role, ['user', 'admin'])) {
            $query->where('role', $request->role);
        }
        
        // Filter by period
        if ($request->filled('period')) {
            if ($request->period === 'this_week') {
                $query->where('created_at', '>=', now()->subDays(7));
            } elseif ($request->period === 'this_month') {
                $query->where('created_at', '>=', now()->subDays(30));
            }
        }
        
        // Sorting
        $sort = $request->get('sort', 'created_at');
        $direction = $request->get('direction', 'desc');
        $allowedSorts = ['id', 'name', 'email', 'role', 'created_at'];
        
        if (!in_array($sort, $allowedSorts)) {
            $sort = 'created_at';
        }
        
        $query->orderBy($sort, $direction);
        
        $users = $query->withCount(['lostItems', 'foundItems'])->paginate(20);
        
        return response()->json([
            'users' => $users,
            'message' => 'Users retrieved successfully'
        ]);
    }
    
    /**
     * Get the current authenticated user
     */
    public function me(Request $request)
    {
        $user = $request->user();
        $user->load(['lostItems', 'foundItems']);
        
        // Get statistics
        $stats = [
            'lost_items' => $user->lostItems()->count(),
            'found_items' => $user->foundItems()->count(),
            'matches' => $this->getUserMatchesCount($user->id),
        ];
        
        return response()->json([
            'user' => $user,
            'stats' => $stats
        ]);
    }
    
    /**
     * Display the specified user
     */
    public function show(User $user)
    {
        $this->authorize('view', $user);
        
        $user->load(['lostItems', 'foundItems']);
        
        $stats = [
            'lost_items' => $user->lostItems()->count(),
            'found_items' => $user->foundItems()->count(),
            'total_matches' => $this->getUserMatchesCount($user->id),
            'confirmed_matches' => $this->getUserMatchesCount($user->id, 'confirmed'),
            'pending_matches' => $this->getUserMatchesCount($user->id, 'pending'),
            'rejected_matches' => $this->getUserMatchesCount($user->id, 'rejected'),
        ];
        
        return response()->json([
            'user' => $user,
            'stats' => $stats
        ]);
    }
    
    /**
     * Update the specified user
     */
    public function update(Request $request, User $user = null)
    {
        // If no user specified, update current user
        if (!$user) {
            $user = Auth::user();
        }
        
        $this->authorize('update', $user);
        
        $validated = $request->validate([
            'name' => ['sometimes', 'string', 'max:255'],
            'email' => ['sometimes', 'string', 'email', 'max:255', Rule::unique('users')->ignore($user->id)],
            'phone' => ['nullable', 'string', 'max:20'],
            'location' => ['nullable', 'string', 'max:255'],
            'latitude' => ['nullable', 'numeric', 'between:-90,90'],
            'longitude' => ['nullable', 'numeric', 'between:-180,180'],
            'profile_photo' => ['nullable', 'image', 'mimes:jpeg,png,jpg,gif', 'max:2048'],
        ]);
        
        // Handle photo upload
        if ($request->hasFile('profile_photo')) {
            if ($user->profile_photo) {
                Storage::disk('public')->delete($user->profile_photo);
            }
            $photoPath = $request->file('profile_photo')->store('profile-photos', 'public');
            $validated['profile_photo'] = $photoPath;
        }
        
        // Handle photo removal
        if ($request->has('remove_photo') && $request->remove_photo) {
            if ($user->profile_photo) {
                Storage::disk('public')->delete($user->profile_photo);
            }
            $validated['profile_photo'] = null;
        }
        
        $user->update($validated);
        
        return response()->json([
            'user' => $user->fresh(),
            'message' => 'Profile updated successfully'
        ]);
    }
    
    /**
     * Remove profile photo
     */
    public function removePhoto(Request $request)
    {
        $user = $request->user();
        
        if ($user->profile_photo) {
            Storage::disk('public')->delete($user->profile_photo);
            $user->update(['profile_photo' => null]);
        }
        
        return response()->json([
            'message' => 'Profile photo removed successfully'
        ]);
    }
    
    /**
     * Update user password
     */
    public function updatePassword(Request $request, User $user = null)
    {
        // If no user specified, update current user
        if (!$user) {
            $user = Auth::user();
        }
        
        $this->authorize('update', $user);
        
        // If updating own password, require current password
        if ($user->id === Auth::id()) {
            $validated = $request->validate([
                'current_password' => ['required', 'current_password'],
                'new_password' => ['required', 'string', 'min:8', 'confirmed'],
            ]);
            $password = Hash::make($validated['new_password']);
        } else {
            // Admin updating another user's password
            $this->authorize('updatePassword', $user);
            $validated = $request->validate([
                'new_password' => ['required', 'string', 'min:8', 'confirmed'],
            ]);
            $password = Hash::make($validated['new_password']);
        }
        
        $user->update(['password' => $password]);
        
        return response()->json([
            'message' => 'Password updated successfully'
        ]);
    }
    
    /**
     * Remove the specified user
     */
    public function destroy(Request $request, User $user)
    {
        $this->authorize('delete', $user);
        
        // Prevent deleting yourself
        if ($user->id === Auth::id()) {
            return response()->json([
                'message' => 'You cannot delete your own account.'
            ], 403);
        }
        
        // Check if user has items before deletion
        $hasItems = $user->lostItems()->exists() || $user->foundItems()->exists();
        
        if ($hasItems && !$request->has('force_delete')) {
            return response()->json([
                'message' => 'User has items. Use force delete option or delete the items first.',
                'has_items' => true
            ], 422);
        }
        
        // Delete profile photo if exists
        if ($user->profile_photo) {
            Storage::disk('public')->delete($user->profile_photo);
        }
        
        $user->delete();
        
        return response()->json([
            'message' => 'User deleted successfully'
        ]);
    }
    
    /**
     * Get user statistics
     */
    public function stats(Request $request, User $user = null)
    {
        if (!$user) {
            $user = Auth::user();
        }
        
        $this->authorize('view', $user);
        
        $lostItems = $user->lostItems();
        $foundItems = $user->foundItems();
        
        $stats = [
            'lost_items' => [
                'total' => $lostItems->count(),
                'pending' => $lostItems->where('status', 'pending')->count(),
                'approved' => $lostItems->where('status', 'approved')->count(),
                'found' => $lostItems->where('status', 'found')->count(),
                'returned' => $lostItems->where('status', 'returned')->count(),
                'rejected' => $lostItems->where('status', 'rejected')->count(),
            ],
            'found_items' => [
                'total' => $foundItems->count(),
                'pending' => $foundItems->where('status', 'pending')->count(),
                'approved' => $foundItems->where('status', 'approved')->count(),
                'claimed' => $foundItems->where('status', 'claimed')->count(),
                'returned' => $foundItems->where('status', 'returned')->count(),
                'disposed' => $foundItems->where('status', 'disposed')->count(),
                'rejected' => $foundItems->where('status', 'rejected')->count(),
            ],
            'matches' => [
                'total' => $this->getUserMatchesCount($user->id),
                'pending' => $this->getUserMatchesCount($user->id, 'pending'),
                'confirmed' => $this->getUserMatchesCount($user->id, 'confirmed'),
                'rejected' => $this->getUserMatchesCount($user->id, 'rejected'),
            ],
            'activity' => [
                'last_active' => $user->updated_at,
                'member_since' => $user->created_at,
            ]
        ];
        
        return response()->json($stats);
    }
    
    /**
     * Search users
     */
    public function search(Request $request)
    {
        $query = $request->get('q', '');
        
        $users = User::where('name', 'like', "%{$query}%")
            ->orWhere('email', 'like', "%{$query}%")
            ->where('id', '!=', Auth::id())
            ->limit(20)
            ->get(['id', 'name', 'email', 'profile_photo']);
        
        return response()->json([
            'users' => $users
        ]);
    }
    
    /**
     * Get user's items
     */
    public function items(Request $request, User $user = null)
    {
        if (!$user) {
            $user = Auth::user();
        }
        
        $this->authorize('view', $user);
        
        $type = $request->get('type', 'all');
        $status = $request->get('status');
        
        $data = [];
        
        if ($type === 'lost' || $type === 'all') {
            $lostQuery = $user->lostItems();
            if ($status) {
                $lostQuery->where('status', $status);
            }
            $data['lost_items'] = $lostQuery->latest()->paginate(10);
        }
        
        if ($type === 'found' || $type === 'all') {
            $foundQuery = $user->foundItems();
            if ($status) {
                $foundQuery->where('status', $status);
            }
            $data['found_items'] = $foundQuery->latest()->paginate(10);
        }
        
        return response()->json($data);
    }
    
    /**
     * Get user's matches
     */
    public function matches(Request $request, User $user = null)
    {
        if (!$user) {
            $user = Auth::user();
        }
        
        $this->authorize('view', $user);
        
        $lostItemIds = $user->lostItems()->pluck('id');
        $foundItemIds = $user->foundItems()->pluck('id');
        
        $matches = ItemMatch::where(function($query) use ($lostItemIds, $foundItemIds) {
                $query->whereIn('lost_item_id', $lostItemIds)
                      ->orWhereIn('found_item_id', $foundItemIds);
            })
            ->with(['lostItem', 'foundItem', 'lostItem.user', 'foundItem.user'])
            ->when($request->status, function($query, $status) {
                return $query->where('status', $status);
            })
            ->orderBy('match_score', 'desc')
            ->paginate(15);
        
        return response()->json([
            'matches' => $matches
        ]);
    }
    
    /**
     * Update user role (Admin only)
     */
    public function updateRole(Request $request, User $user)
    {
        $this->authorize('updateRole', $user);
        
        $validated = $request->validate([
            'role' => ['required', 'in:user,admin']
        ]);
        
        $user->update(['role' => $validated['role']]);
        
        return response()->json([
            'user' => $user,
            'message' => 'User role updated successfully'
        ]);
    }
    
    /**
     * Toggle user active status (Admin only)
     */
    public function toggleActive(User $user)
    {
        $this->authorize('update', $user);
        
        $user->update(['is_active' => !$user->is_active]);
        
        return response()->json([
            'user' => $user,
            'message' => $user->is_active ? 'User activated' : 'User deactivated'
        ]);
    }
    
    /**
     * Get user's recent activity
     */
    public function recentActivity(Request $request, User $user = null)
    {
        if (!$user) {
            $user = Auth::user();
        }
        
        $this->authorize('view', $user);
        
        $recentLost = $user->lostItems()->latest()->limit(5)->get();
        $recentFound = $user->foundItems()->latest()->limit(5)->get();
        
        $lostItemIds = $user->lostItems()->pluck('id');
        $foundItemIds = $user->foundItems()->pluck('id');
        
        $recentMatches = ItemMatch::where(function($query) use ($lostItemIds, $foundItemIds) {
                $query->whereIn('lost_item_id', $lostItemIds)
                      ->orWhereIn('found_item_id', $foundItemIds);
            })
            ->with(['lostItem', 'foundItem'])
            ->latest()
            ->limit(10)
            ->get();
        
        return response()->json([
            'recent_lost_items' => $recentLost,
            'recent_found_items' => $recentFound,
            'recent_matches' => $recentMatches
        ]);
    }
    
    /**
     * Helper method to get user matches count
     */
    private function getUserMatchesCount($userId, $status = null)
    {
        $lostItemIds = LostItem::where('user_id', $userId)->pluck('id');
        $foundItemIds = FoundItem::where('user_id', $userId)->pluck('id');
        
        $query = ItemMatch::where(function($q) use ($lostItemIds, $foundItemIds) {
            $q->whereIn('lost_item_id', $lostItemIds)
              ->orWhereIn('found_item_id', $foundItemIds);
        });
        
        if ($status) {
            $query->where('status', $status);
        }
        
        return $query->count();
    }
}
